import os

def create_admin_key():
    """Tạo file admin.key trong thư mục hiện tại"""
    filename = "admin.key"
    try:
        with open(filename, 'w') as f:
            # Có thể ghi nội dung gì đó (hoặc để trống)
            f.write("ADMIN_KEY_FOR_KE_TOAN_PRO")
        print(f"✅ Đã tạo file {filename} trong thư mục: {os.getcwd()}")
    except Exception as e:
        print(f"❌ Lỗi khi tạo file: {e}")

if __name__ == "__main__":
    create_admin_key()